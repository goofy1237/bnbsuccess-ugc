# ── Supabase ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Fish Audio (Voice Clone TTS) ──
FISH_AUDIO_API_KEY=your-fish-audio-api-key
FISH_AUDIO_VOICE_ID=your-cloned-voice-id

# ── fal.ai (Kling Lip Sync + Seedance B-Roll) ──
FAL_KEY=your-fal-ai-key

# ── Anthropic (Script Generation) ──
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── OpenAI (Sora B-Roll fallback + Whisper) ──
OPENAI_API_KEY=your-openai-api-key

# ── Slack (Notifications) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#ugc-pipeline

# ── Telegram (Notifications) ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Meta Ads API (Feedback Loop) ──
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=act_123456789

# ── Hyros (Attribution) ──
HYROS_API_KEY=your-hyros-api-key

# ── Pipeline Config ──
FACE_REFERENCE_URL=https://your-storage.com/face-ref/ava-reference.mp4
DEFAULT_VOICE_SPEED=1.0
DEFAULT_VOICE_TEMP=0.7
TARGET_WPM=140
